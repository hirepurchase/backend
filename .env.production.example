# Production Environment Variables for SmarterASP.NET
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=production
PORT=8080

# Database (Supabase)
DATABASE_URL="postgresql://user:password@host:6543/database?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/database"

# JWT Secret (Generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (Your Vercel deployment)
FRONTEND_URL=https://your-app.vercel.app

# API URL (Your SmarterASP.NET domain)
API_URL=https://yourdomain.smarterasp.net

# Background jobs / runtime
ENABLE_IDLE_SHUTDOWN=false

# Knox Guard
# Keep dry-run enabled until you have confirmed the live tenant settings and endpoint paths.
#
# Regional base URLs (pick the one matching your Samsung tenant):
#   US production:  https://us-kcs-api.samsungknox.com/kcs/v1.1/kg
#   EU production:  https://eu-kcs-api.samsungknox.com/kcs/v1.1/kg
#   US integration: https://us-kcs-api.samsungknox.com/kcs/v1.1/kg-integration
#   EU integration: https://eu-kcs-api.samsungknox.com/kcs/v1.1/kg-integration
KNOX_GUARD_BASE_URL=https://us-kcs-api.samsungknox.com/kcs/v1.1/kg-integration

# Static API token (generated via Samsung Knox API Portal + private-key signing).
# Tokens expire every 30 minutes; replace this before live use or configure auto-refresh below.
KNOX_GUARD_API_TOKEN=your-x-knox-apitoken

# Auto-refresh via Knox Cloud Authentication (recommended for production).
# Set these to enable automatic token generation — tokens are refreshed every 28 minutes.
#
# KNOX_GUARD_CLIENT_IDENTIFIER — the full JWT from the Knox API Portal
#   (starts with eyJ..., found in the portal under API Keys → Client Identifier)
#
# KNOX_GUARD_PRIVATE_KEY_PATH — path to your private key file.
#   From keys.json: copy the "Private" value into a file (e.g. ./certs/knox-private.key).
#   The service accepts either raw base64 PKCS#8 DER or a full PEM file.
#
# Token flow: sign(clientIdentifier) → POST /accessToken → sign(accessToken) → x-knox-apitoken
#
# KNOX_GUARD_CLIENT_IDENTIFIER=eyJhbGciOiJIUzUxMiJ9...
# KNOX_GUARD_PRIVATE_KEY_PATH=./certs/knox-private.key

KNOX_GUARD_DRY_RUN=true
KNOX_GUARD_ENABLE_LIVE_ACTIONS=false
KNOX_GUARD_TIMEOUT_MS=15000
KNOX_GUARD_WEBHOOK_CERT_PATH=./certs/samsung-knox-webhook.pem
# Or provide the certificate inline instead of a file path.
# KNOX_GUARD_WEBHOOK_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Knox Guard endpoint paths
# These match Samsung's v1.1.x REST API paths exactly.
KNOX_GUARD_CHECK_AUTH_PATH=/authorization
KNOX_GUARD_LIST_DEVICES_PATH=/devices/list
KNOX_GUARD_UPLOAD_DEVICES_PATH=/devices/uploads
KNOX_GUARD_APPROVE_DEVICE_PATH=/devices/approve
KNOX_GUARD_LOCK_DEVICE_PATH=/devices/lock
KNOX_GUARD_UNLOCK_DEVICE_PATH=/devices/unlock
KNOX_GUARD_BLINK_DEVICE_PATH=/devices/blink
KNOX_GUARD_SEND_MESSAGE_PATH=/devices/sendMessage
KNOX_GUARD_COMPLETE_DEVICE_PATH=/devices/complete
KNOX_GUARD_CANCEL_COMPLETE_PATH=/devices/cancelComplete

# Hubtel Payment Gateway
HUBTEL_POS_SALES_ID=your-hubtel-sales-id
HUBTEL_API_KEY=your-hubtel-api-key
HUBTEL_API_SECRET=your-hubtel-api-secret
HUBTEL_CALLBACK_URL=https://yourdomain.smarterasp.net/api/payments/hubtel/callback
HUBTEL_PREAPPROVAL_CALLBACK_URL=https://yourdomain.smarterasp.net/api/payments/hubtel/preapproval/callback
WEBHOOK_SHARED_TOKEN=replace-with-a-long-random-string

# Nalo SMS Configuration
ENABLE_SMS_NOTIFICATIONS=true
NALO_API_URL=https://api.nalosolutions.com/sms/v1/text/single
NALO_API_KEY=your-nalo-api-key
NALO_SENDER_ID=HIREPURCHASE

# Email Configuration
ENABLE_EMAIL_NOTIFICATIONS=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=Hire Purchase System <noreply@hirepurchase.com>

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Security
BCRYPT_ROUNDS=10
